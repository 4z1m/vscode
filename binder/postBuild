#!/bin/bash

mkdir -p ~/.jupyter

cat > ~/.jupyter/jupyter_server_config.py << 'EOF'
c.ServerProxy.servers = {
    'code': {
        'command': [
            'code-server',
            '--auth', 'none',
            '--bind-addr', '0.0.0.0:{port}'
        ],
        'timeout': 60,
        'launcher_entry': {
            'title': 'VS Code'
        }
    }
}
EOF
